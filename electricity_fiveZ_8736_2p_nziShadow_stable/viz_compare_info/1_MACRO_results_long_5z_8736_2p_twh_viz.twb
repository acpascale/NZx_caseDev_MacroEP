      <aliases enabled='yes' />
      <column caption='energyBalanceNR' datatype='real' name='[Calculation_123286081362628609]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF CONTAINS([component_id], &apos;_charge_&apos;) THEN -[value]&#13;&#10;ELSEIF CONTAINS([component_id], &apos;NR_to_ER&apos;) THEN -[value]&#13;&#10;ELSEIF CONTAINS([component_id], &apos;NR_to_WR&apos;) THEN -[value]&#13;&#10;ELSEIF CONTAINS([component_id], &apos;NR_to_NER&apos;) THEN -[value]&#13;&#10;ELSE [value]&#13;&#10;END' />
      </column>
      <column caption='Calculation1' datatype='real' name='[Calculation_1515461322792792065]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF CONTAINS([component_id], &apos;nuclear&apos;) THEN -[value]&#13;&#10;ELSEIF CONTAINS([component_id], &apos;coal&apos;) THEN -[value]&#13;&#10;ELSEIF CONTAINS([component_id], &apos;NG&apos;) THEN -[value]&#13;&#10;ELSEIF CONTAINS([component_id], &apos;biomass&apos;) THEN -[value]&#13;&#10;ELSE [value]&#13;&#10;END' />
      </column>
