      <column caption='energyBalanceWR' datatype='real' name='[energyBalanceCT (copy)_123286081368879112]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF CONTAINS([component_id], &apos;_charge_&apos;) THEN -[value]&#13;&#10;ELSEIF CONTAINS([component_id], &apos;WR_to_SR&apos;) THEN -[value]&#13;&#10;ELSEIF CONTAINS([component_id], &apos;WR_to_ER&apos;) THEN -[value]&#13;&#10;ELSEIF CONTAINS([component_id], &apos;NR_to_WR&apos;) THEN [value]&#13;&#10;ELSE [value]&#13;&#10;END' />
