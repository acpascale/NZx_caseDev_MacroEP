    <worksheet name='PIER_Elec_2024_gwh'>
      <layout-options>
        <title>
          <formatted-text>
            <run>PIER Electricity Suply 2024</run>
            <run fontalignment='1'>Æ&#10;</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='SupplyFromECTiy' name='federated.0082o1i19z4sg817yymp90o2zdj4' />
          </datasources>
          <datasource-dependencies datasource='federated.0082o1i19z4sg817yymp90o2zdj4'>
            <column caption='Month-wise calculation' datatype='real' name='[Calculation_2636294698840956929]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [Season] IN (&apos;S02May&apos;,&apos;S04Jul&apos;,&apos;S05Aug&apos;,&apos;S07Oct&apos;,&apos;S09Dec&apos;,&apos;S10Jan&apos;,&apos;S12Mar&apos;) THEN [SupplyFromECTiy] * 31&#13;&#10;ELSEIF [Season] IN (&apos;S01Apr&apos;,&apos;S03Jun&apos;,&apos;S06Sep&apos;,&apos;S08Nov&apos;) THEN [SupplyFromECTiy] * 30&#13;&#10;ELSE [SupplyFromECTiy] *28&#13;&#10;END' />
            </column>
            <column caption='SUM([Month-wise calculation])/1e3' datatype='real' name='[Calculation_2636294698842939394]' role='measure' type='quantitative' user:unnamed='PIER_Elec_2024_gwh'>
              <calculation class='tableau' formula='SUM([Calculation_2636294698840956929])/1e3' />
            </column>
