DATch$EG_OCGT_ALL_ALL <- DATch$EG_OCGT_ALL_ALL * 0.85
DATch$EG_PHWR_ALL_ALL <- DATch$EG_PHWR_ALL_ALL * 0.709166667
DATch$EG_SMR_ALL_ALL  <- DATch$EG_SMR_ALL_ALL  * 0.709166667
