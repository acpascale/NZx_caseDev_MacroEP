    <worksheet name='PrimaryEnergy_National_hr'>
      <table>
        <view>
          <datasources>
            <datasource caption='flows' name='federated.06yixiz0dww1op18jhttw071q923' />
          </datasources>
          <datasource-dependencies datasource='federated.06yixiz0dww1op18jhttw071q923'>
            <column caption='Calculation1' datatype='real' name='[Calculation_1515461322792792065]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF CONTAINS([component_id], &apos;nuclear&apos;) THEN -[value]&#13;&#10;ELSEIF CONTAINS([component_id], &apos;coal&apos;) THEN -[value]&#13;&#10;ELSEIF CONTAINS([component_id], &apos;NG&apos;) THEN -[value]&#13;&#10;ELSE [value]&#13;&#10;END' />
            </column>
            <column caption='SUM([Calculation1])/1e3' datatype='real' name='[Calculation_2254896088767492097]' role='measure' type='quantitative' user:unnamed='PrimaryEnergy_National_hr'>
              <calculation class='tableau' formula='SUM([Calculation_1515461322792792065])/1e3' />
            </column>
            <column datatype='string' name='[Component Id (group)]' role='dimension' type='nominal'>
              <calculation class='categorical-bin' column='[component_id]' new-bin='true'>
                <bin default-name='false' value='&quot;BatteryStorage&quot;'>
                  <value>&quot;ER_battery_discharge_edge&quot;</value>
                  <value>&quot;NER_battery_discharge_edge&quot;</value>
                  <value>&quot;NR_battery_discharge_edge&quot;</value>
                  <value>&quot;SR_battery_discharge_edge&quot;</value>
                  <value>&quot;WR_battery_discharge_edge&quot;</value>
                </bin>
                <bin default-name='false' value='&quot;Biomass demand from Elec&quot;'>
                  <value>&quot;ER_biomass_fuel_edge&quot;</value>
                  <value>&quot;NER_biomass_fuel_edge&quot;</value>
                  <value>&quot;NR_biomass_fuel_edge&quot;</value>
                  <value>&quot;SR_biomass_fuel_edge&quot;</value>
                  <value>&quot;WR_biomass_fuel_edge&quot;</value>
                </bin>
                <bin default-name='false' value='&quot;CO2&quot;'>
                  <value>&quot;CO2_Injection_1_co2_captured_edge&quot;</value>
                  <value>&quot;CO2_Injection_1_co2_storage_edge&quot;</value>
                  <value>&quot;CO2_Injection_10_co2_captured_edge&quot;</value>
                  <value>&quot;CO2_Injection_10_co2_storage_edge&quot;</value>
